# =============================================
# Spaza Project - Root .gitignore
# =============================================

# Exclude folders NOT part of this repo
consumer_app/
Script database/
docs/
.sixth/
start-all.bat

# IDE / Editor
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.slnLaunch.user

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Log files
*.log

# Uploads (user data - never commit)
**/uploads/

# =============================================
# .NET / C# (SpazaSure.Backend)
# =============================================
**/bin/
**/obj/
**/out/
*.dll
*.exe
*.pdb
*.cache
*.nupkg

# .NET User secrets
SpazaSure.Backend/.env.qa
SpazaSure.Backend/.env.prod

# =============================================
# Flutter / Dart (spazasure_app)
# =============================================
spazasure_app/.dart_tool/
spazasure_app/.flutter-plugins-dependencies
spazasure_app/.pub-cache/
spazasure_app/.pub/
spazasure_app/build/
spazasure_app/coverage/
spazasure_app/.idea/
spazasure_app/*.iml

# =============================================
# Node.js / React (supplier-portal)
# =============================================
supplier-portal/node_modules/
supplier-portal/dist/
supplier-portal/.env
supplier-portal/.env.local
supplier-portal/.env.*.local
