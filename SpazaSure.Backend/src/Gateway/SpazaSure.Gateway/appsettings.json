{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "AllowedHosts":  "*",
    "ReverseProxy":  {
                         "Routes":  {
                                        "auth-route":  {
                                                           "ClusterId":  "auth-cluster",
                                                           "Match":  {
                                                                         "Path":  "/api/supplier/auth/{**catch-all}"
                                                                     }
                                                       },
                                        "shop-auth-route":  {
                                                                "ClusterId":  "auth-cluster",
                                                                "Match":  {
                                                                              "Path":  "/api/shop/auth/{**catch-all}"
                                                                          }
                                                            },
                                        "products-route":  {
                                                               "ClusterId":  "product-cluster",
                                                               "Match":  {
                                                                             "Path":  "/api/supplier/products/{**catch-all}"
                                                                         }
                                                           },
                                        "orders-route":  {
                                                             "ClusterId":  "order-cluster",
                                                             "Match":  {
                                                                           "Path":  "/api/supplier/orders/{**catch-all}"
                                                                       }
                                                         },
                                        "analytics-route":  {
                                                                "ClusterId":  "analytics-cluster",
                                                                "Match":  {
                                                                              "Path":  "/api/supplier/analytics/{**catch-all}"
                                                                          }
                                                            },
                                        "profile-route":  {
                                                              "ClusterId":  "user-cluster",
                                                              "Match":  {
                                                                            "Path":  "/api/supplier/profile/{**catch-all}"
                                                                        }
                                                          },
                                        "subscription-route":  {
                                                                   "ClusterId":  "user-cluster",
                                                                   "Match":  {
                                                                                 "Path":  "/api/supplier/subscription/{**catch-all}"
                                                                             }
                                                               },
                                        "payment-route":  {
                                                              "ClusterId":  "user-cluster",
                                                              "Match":  {
                                                                            "Path":  "/api/supplier/payment/{**catch-all}"
                                                                        }
                                                          },
                                        "compliance-route":  {
                                                                 "ClusterId":  "compliance-cluster",
                                                                 "Match":  {
                                                                               "Path":  "/api/compliance/{**catch-all}"
                                                                           }
                                                             },
                                        "uploads-route":  {
                                                              "ClusterId":  "user-cluster",
                                                              "Match":  {
                                                                            "Path":  "/uploads/{**catch-all}"
                                                                        }
                                                          },
                                        "shop-marketplace-route":  {
                                                                       "Match":  {
                                                                                     "Path":  "/api/shop/marketplace/{**catch-all}"
                                                                                 },
                                                                       "ClusterId":  "product-cluster"
                                                                   },
                                        "shop-orders-route":  {
                                                                  "Match":  {
                                                                                "Path":  "/api/shop/orders/{**catch-all}"
                                                                            },
                                                                  "ClusterId":  "order-cluster"
                                                              },
                                        "admin-route":  {
                                                            "ClusterId":  "user-cluster",
                                                            "Match":  {
                                                                          "Path":  "/api/admin/{**catch-all}"
                                                                      }
                                                        },
                                        "admin-orders-route":  {
                                                            "ClusterId":  "order-cluster",
                                                            "Match":  {
                                                                          "Path":  "/api/admin/orders/{**catch-all}"
                                                                      }
                                                        },
                                        "shop-profile-route":  {
                                                                   "ClusterId":  "user-cluster",
                                                                   "Match":  {
                                                                                 "Path":  "/api/shop/profile/{**catch-all}"
                                                                             }
                                                               },
                                        "notification-route":  {
                                                                   "ClusterId":  "notification-cluster",
                                                                   "Match":  {
                                                                                 "Path":  "/api/supplier/notifications/{**catch-all}"
                                                                             }
                                                               },
                                        "shop-notification-route":  {
                                                                   "ClusterId":  "notification-cluster",
                                                                   "Match":  {
                                                                                 "Path":  "/api/shop/notifications/{**catch-all}"
                                                                             }
                                                               }
                                    },
                         "Clusters":  {
                                          "auth-cluster":  {
                                                               "Destinations":  {
                                                                                    "auth":  {
                                                                                                 "Address":  "http://localhost:5001"
                                                                                             }
                                                                                }
                                                           },
                                          "product-cluster":  {
                                                                  "Destinations":  {
                                                                                       "product":  {
                                                                                                       "Address":  "http://localhost:5002"
                                                                                                   }
                                                                                   }
                                                              },
                                          "order-cluster":  {
                                                                "Destinations":  {
                                                                                     "order":  {
                                                                                                   "Address":  "http://localhost:5003"
                                                                                               }
                                                                                 }
                                                            },
                                          "analytics-cluster":  {
                                                                    "Destinations":  {
                                                                                         "analytics":  {
                                                                                                           "Address":  "http://localhost:5004"
                                                                                                       }
                                                                                     }
                                                                },
                                          "user-cluster":  {
                                                               "Destinations":  {
                                                                                    "user":  {
                                                                                                 "Address":  "http://localhost:5005"
                                                                                             }
                                                                                }
                                                           },
                                          "compliance-cluster":  {
                                                                     "Destinations":  {
                                                                                          "compliance":  {
                                                                                                             "Address":  "http://localhost:5006"
                                                                                                         }
                                                                                      }
                                                                 },
                                          "notification-cluster":  {
                                                                       "Destinations":  {
                                                                                            "notification":  {
                                                                                                                 "Address":  "http://localhost:5184"
                                                                                                             }
                                                                                        }
                                                                   }
                                      }
                     }
}
