# Production Environment Configuration
# This file is used when running: npm run build (or npm run build:prod)

# API Base URL - Production backend server
# Replace with your actual production backend URL
VITE_API_URL=https://api.spazasure.co.za/api

# App Configuration
VITE_APP_NAME=SpazaSure Supplier Portal
VITE_APP_ENV=production

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false

# Other settings
VITE_API_TIMEOUT=30000
