# Docker Compose Environment Variables
# Copy this file to .env in the same directory as docker-compose.yml

# ============ RabbitMQ ============
RABBITMQ_USER=spazasure_prod
RABBITMQ_PASS=CHANGE_ME_STRONG_PASSWORD

# ============ SQL Server ============
MSSQL_SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============ Backend API ============
